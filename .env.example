PORT=5000
CLIENT_URLS=https://your-admin-portal.example.com,https://your-user-portal.example.com
DB_HOST=your-render-postgres-host
DB_PORT=5432
DB_NAME=hrmsdb
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_DIALECT=postgres
# Preferred for local connection to Render Postgres:
# DATABASE_URL=postgresql://user:password@external-render-host/database
# DB_SSL=true
MAIL_MODE=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USER=Info@infolinx.com
MAIL_PASSWORD=store-real-password-only-in-local-env
MAIL_FROM=Info@infolinx.com
COMPANY_EMAIL_DOMAIN=infolinx.com
# For Microsoft 365 tenants where Security Defaults blocks SMTP basic auth,
# set MAIL_MODE=graph and grant Microsoft Graph Application permission: Mail.Send.
MS_GRAPH_MAIL_USER_ID=Info@infolinx.com
JWT_DEMO_SECRET=replace-this-before-production

# Microsoft Graph / Teams integration
MS_GRAPH_TENANT_ID=your-azure-tenant-id
MS_GRAPH_CLIENT_ID=your-azure-app-client-id
MS_GRAPH_CLIENT_SECRET=your-azure-app-client-secret
MS_GRAPH_USER_ID=hr-or-scheduler-user@yourcompany.com

# Google Calendar integration
GOOGLE_CALENDAR_ID=primary-or-shared-calendar-id
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
